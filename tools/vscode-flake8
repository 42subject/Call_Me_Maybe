#!/usr/bin/env python3
"""Normalize VS Code flake8 extension arguments before running flake8."""

from __future__ import annotations

import subprocess
import sys


def normalize_arg(arg: str) -> str:
    prefix = "--format="
    if arg.startswith(prefix):
        value = arg[len(prefix):]
        if len(value) >= 2 and value[0] == "'" and value[-1] == "'":
            return f"{prefix}{value[1:-1]}"
    return arg


def main() -> int:
    args = [normalize_arg(arg) for arg in sys.argv[1:]]
    completed = subprocess.run(["uv", "run", "flake8", *args], check=False)
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
